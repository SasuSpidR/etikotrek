/* Reset & Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    /* Alpine Editorial Design System - Tons Verts/Beiges */
    --primary-color: #2D4B3F;
    --primary-container: #3d5f50;
    --secondary-color: #6B7C5A;
    --secondary-container: #c5d7b7;
    --tertiary-color: #B8A488;
    --tertiary-container: #d4c4ac;
    --accent-color: #7A9B6E;
    --surface-tint: #5a8a4d;
    --background: #f4fbf8;
    --surface: #f4fbf8;
    --surface-container-low: #eef5f2;
    --surface-container: #e9efec;
    --surface-container-high: #e3eae7;
    --surface-container-highest: #dde4e1;
    --surface-container-lowest: #ffffff;
    --on-surface: #161d1b;
    --on-primary: #ffffff;
    --outline-variant: #c1c8c3;
    --text-dark: #161d1b;
    --text-light: #414845;
    --white: #ffffff;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Work Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    line-height: 1.6;
    color: var(--text-dark);
    background: var(--background);
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* Header - Glassmorphism */
.header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(244, 251, 248, 0.7);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(193, 200, 195, 0.15);
    z-index: 1000;
}

.nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
}

.logo h2 {
    color: var(--primary-color);
    font-size: 1.5rem;
    letter-spacing: 2px;
}

.nav-menu {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
}

.nav-menu a {
    text-decoration: none;
    color: var(--text-dark);
    font-weight: 500;
    transition: color 0.3s;
}

.nav-menu a:hover {
    color: var(--primary-color);
}

/* Buttons */
.btn-primary {
    background: var(--accent-color);
    color: var(--white);
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    transition: all 0.3s;
}

.btn-primary:hover {
    background: var(--surface-tint);
    color: var(--white) !important;
    transform: translateY(-1px);
}

.btn-hero {
    display: inline-block;
    background: linear-gradient(135deg, var(--accent-color), var(--surface-tint));
    color: var(--white);
    padding: 1rem 2.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s;
}

.btn-hero:hover {
    background: linear-gradient(135deg, var(--surface-tint), var(--accent-color));
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(242, 112, 54, 0.3);
}

.btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--white);
    padding: 1rem 2.5rem;
    border-radius: 5px;
    border: 2px solid var(--white);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s;
}

.btn-secondary:hover {
    background: var(--white);
    color: var(--primary-color);
}

/* Hero Section */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.4)),
                url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    text-align: center;
    color: var(--white);
    margin-top: 70px;
}

.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(61, 107, 46, 0.3), rgba(31, 58, 26, 0.5));
}

.hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    padding: 2rem;
}

.hero-tag {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    padding: 0.5rem 1.5rem;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.hero-title {
    font-family: 'Epilogue', sans-serif;
    font-size: 5.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.4);
    line-height: 1.1;
}

.hero-subtitle {
    font-family: 'Epilogue', sans-serif;
    font-size: 2rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: 2rem;
    opacity: 0.95;
    letter-spacing: -0.01em;
}

.hero-description {
    font-family: 'Work Sans', sans-serif;
    font-size: 1rem;
    margin-bottom: 3rem;
    line-height: 1.6;
    opacity: 0.85;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

/* Introduction */
.intro {
    padding: 8rem 0;
    background: var(--surface);
}

.intro-content {
    max-width: 1100px;
    margin: 0 auto;
}

.intro h2 {
    font-family: 'Epilogue', sans-serif;
    font-size: 3.5rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: 3rem;
    text-align: center;
    letter-spacing: -0.02em;
    line-height: 1.2;
}

.intro-with-image {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 4rem;
    align-items: center;
    position: relative;
}

.intro-text-content {
    text-align: left;
    padding-right: 2rem;
}

.intro-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-light);
    margin-bottom: 1.5rem;
}

.intro-image {
    position: relative;
    margin-right: -5rem;
}

.intro-image img {
    width: 120%;
    height: 500px;
    object-fit: cover;
    border-radius: 0.5rem;
    box-shadow: 0 8px 32px rgba(22, 29, 27, 0.15);
}

/* Galerie */
.galerie {
    padding: 8rem 0;
    background: var(--surface-container-low);
}

.galerie-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
}

.galerie-item {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    height: 300px;
    cursor: pointer;
}

.galerie-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.galerie-item:hover img {
    transform: scale(1.1);
}

.galerie-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    color: var(--white);
    padding: 2rem 1.5rem 1.5rem;
    transform: translateY(100%);
    transition: transform 0.3s ease;
}

.galerie-item:hover .galerie-overlay {
    transform: translateY(0);
}

.galerie-overlay p {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
}

/* Section Titles - Alpine Editorial Style */
.section-title {
    font-family: 'Epilogue', sans-serif;
    text-align: center;
    font-size: 3.5rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: 4rem;
    margin-top: 6rem;
    position: relative;
    letter-spacing: -0.02em;
    line-height: 1.2;
}

/* Programme */
.programme {
    padding: 8rem 0;
    background: var(--surface-container-low);
}

.programme-grid {
    display: grid;
    gap: 4rem;
    max-width: 1400px;
    margin: 0 auto;
}

.day-card {
    background: var(--surface-container-lowest);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: transform 0.3s;
}

.day-card:hover {
    transform: translateY(-5px);
}

.day-image {
    width: 100%;
    height: 280px;
    overflow: hidden;
    position: relative;
}

.day-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
}

.day-card:hover .day-image img {
    transform: scale(1.05);
}

.day-header {
    background: transparent;
    color: var(--on-surface);
    padding: 2.5rem 2.5rem 1rem 2.5rem;
    text-align: left;
}

.day-number {
    display: inline-block;
    background: transparent;
    padding: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tertiary-color);
    margin-bottom: 0.75rem;
}

.day-header h3 {
    font-family: 'Epilogue', sans-serif;
    font-size: 2rem;
    font-weight: 600;
    margin: 0.5rem 0;
    letter-spacing: -0.01em;
    color: var(--primary-color);
}

.day-tagline {
    font-style: italic;
    opacity: 0.9;
    margin-top: 0.5rem;
}

.day-content {
    padding: 0 2.5rem 2.5rem 2.5rem;
}

.day-activity {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    align-items: flex-start;
}

.day-activity .icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.day-activity strong {
    font-family: 'Work Sans', sans-serif;
    color: var(--primary-color);
    display: block;
    font-size: 1.125rem;
    font-weight: 600;
}

.day-activity p {
    font-family: 'Work Sans', sans-serif;
    color: var(--text-light);
    margin-top: 0.25rem;
    font-size: 0.875rem;
}

.day-description {
    margin: 1.5rem 0;
    line-height: 1.8;
    color: var(--text-light);
}

.day-highlight {
    background: var(--light-color);
    padding: 1rem;
    border-radius: 5px;
    margin: 1rem 0;
    border-left: 3px solid var(--accent-color);
}

.day-info {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
}

.info-badge {
    background: var(--surface-container-high);
    color: var(--primary-color);
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* Guides */
.guides {
    padding: 8rem 0;
    background: var(--surface);
}

.guides-intro {
    text-align: center;
    font-family: 'Work Sans', sans-serif;
    font-size: 1rem;
    color: var(--text-light);
    max-width: 700px;
    margin: 0 auto 4rem;
    line-height: 1.6;
    font-style: italic;
}

.guides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 2rem;
}

.guide-card {
    background: var(--surface-container-lowest);
    border-radius: 0.5rem;
    padding: 3rem;
}

.guide-content h3 {
    font-family: 'Epilogue', sans-serif;
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
}

.guide-title {
    font-weight: 600;
    color: var(--tertiary-color);
    margin-bottom: 1rem;
}

.guide-bio {
    line-height: 1.8;
    color: var(--text-light);
    margin-bottom: 1rem;
}

.guide-contact {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--secondary-color);
}

/* Tarifs */
.tarifs {
    padding: 8rem 0;
    background: var(--surface-container-low);
}

.tarifs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
    margin-bottom: 3rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
}

.tarif-card {
    background: var(--surface-container-lowest);
    border-radius: 0.5rem;
    padding: 3rem;
    text-align: center;
    position: relative;
    transition: transform 0.3s;
}

.tarif-card:hover {
    transform: translateY(-3px);
}

.tarif-card.featured {
    background: linear-gradient(135deg, rgba(242, 112, 54, 0.05), rgba(166, 59, 0, 0.05));
    box-shadow: 0 8px 32px rgba(242, 112, 54, 0.1);
}

.badge-popular {
    position: absolute;
    top: -15px;
    right: 20px;
    background: var(--accent-color);
    color: var(--white);
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
}

.tarif-header h3 {
    font-family: 'Epilogue', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: 1rem;
}

.price {
    font-family: 'Epilogue', sans-serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary-color);
    margin: 1rem 0;
}

.price-original {
    font-size: 1.8rem;
    color: var(--text-light);
    text-decoration: line-through;
    margin-bottom: 0.5rem;
}

.price-subtitle {
    color: var(--text-light);
    margin-bottom: 0.5rem;
}

.price-detail {
    font-size: 0.95rem;
    color: var(--accent-color);
    font-weight: 600;
    margin-bottom: 1.5rem;
}

.tarif-features {
    list-style: none;
    margin: 2rem 0;
    text-align: left;
}

.tarif-features li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--light-color);
    color: var(--text-dark);
}

.btn-tarif {
    display: block;
    background: linear-gradient(135deg, var(--accent-color), var(--surface-tint));
    color: var(--white);
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
    margin-top: 1.5rem;
}

.btn-tarif:hover {
    background: linear-gradient(135deg, var(--surface-tint), var(--accent-color));
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(242, 112, 54, 0.3);
}

.tarif-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
}

.tarif-included,
.tarif-options,
.tarif-excluded {
    background: var(--white);
    padding: 2rem;
    border-radius: 10px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
}

.tarif-details h4 {
    color: var(--primary-color);
    margin-bottom: 1rem;
    font-size: 1.3rem;
}

.tarif-details ul {
    list-style: none;
}

.tarif-details li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
}

.tarif-details li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--accent-color);
    font-weight: bold;
}

/* Qualité */
.qualite {
    padding: 8rem 0;
    background: var(--surface);
}

.qualite-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
}

.qualite-card {
    text-align: center;
    padding: 2.5rem;
    background: var(--surface-container-lowest);
    border-radius: 0.5rem;
}

.qualite-card h3 {
    color: var(--primary-color);
    margin-bottom: 1rem;
    font-size: 1.3rem;
}

.qualite-card p {
    color: var(--text-light);
    line-height: 1.6;
}

/* Agence */
.agence {
    padding: 8rem 0;
    background: var(--surface-container-low);
}

.agence-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
}

.agence-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-light);
    margin-bottom: 1.5rem;
}

.agence-certification {
    background: var(--surface-container-lowest);
    padding: 1.5rem;
    border-radius: 0.5rem;
    border-left: 4px solid var(--accent-color);
}

.agence-contact {
    margin-top: 2rem;
    font-size: 1.3rem;
}

/* CTA Final */
.cta-final {
    padding: 8rem 0;
    background: linear-gradient(135deg, var(--primary-color), var(--primary-container));
    color: var(--white);
    text-align: center;
}

.cta-content h2 {
    font-family: 'Epilogue', sans-serif;
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
}

.cta-content p {
    font-size: 1.2rem;
    margin-bottom: 1rem;
}

.cta-date {
    font-family: 'Epilogue', sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    margin: 2rem 0 3rem 0;
    letter-spacing: -0.01em;
}

.cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-cta {
    display: inline-block;
    background: var(--white);
    color: var(--primary-color);
    padding: 1rem 2.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s;
}

.btn-cta:hover {
    background: var(--accent-color);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(242, 112, 54, 0.4);
}

.btn-cta-secondary {
    display: inline-block;
    background: transparent;
    color: var(--white);
    padding: 1rem 2.5rem;
    border-radius: 5px;
    border: 2px solid var(--white);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s;
}

.btn-cta-secondary:hover {
    background: var(--white);
    color: var(--primary-color);
}

/* Footer */
.footer {
    background: var(--primary-color);
    color: var(--white);
    padding: 3rem 0 1rem;
}

.footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
}

.footer h3,
.footer h4 {
    font-family: 'Epilogue', sans-serif;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.footer ul {
    list-style: none;
}

.footer ul li {
    margin-bottom: 0.5rem;
}

.footer a {
    color: var(--white);
    text-decoration: none;
    transition: color 0.3s;
}

.footer a:hover {
    color: var(--secondary-color);
}

.footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
}

/* Responsive */
@media (max-width: 768px) {
    .nav-menu {
        flex-direction: column;
        gap: 1rem;
    }

    .hero-title {
        font-size: 2.5rem;
    }

    .hero-subtitle {
        font-size: 1.3rem;
    }

    .section-title {
        font-size: 2rem;
    }

    .intro-with-image {
        grid-template-columns: 1fr;
    }

    .intro-text-content {
        text-align: center;
    }

    .galerie-grid {
        grid-template-columns: 1fr;
    }

    .guides-grid {
        grid-template-columns: 1fr;
    }

    .tarifs-grid {
        grid-template-columns: 1fr;
    }

    .hero-cta {
        flex-direction: column;
    }

    .cta-buttons {
        flex-direction: column;
    }
}
